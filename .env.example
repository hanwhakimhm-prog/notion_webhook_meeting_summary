# ── Notion 멀티 워크스페이스 ──────────────────────────────
# 워크스페이스를 추가할 때마다 _N 숫자를 늘려서 쌍으로 추가
WORKSPACE_ID_1=your-workspace-id-here        # 워크스페이스 A의 ID
NOTION_TOKEN_WS_1=secret_xxx                 # 워크스페이스 A의 Integration Token

WORKSPACE_ID_2=your-second-workspace-id      # 워크스페이스 B의 ID (필요 시)
NOTION_TOKEN_WS_2=secret_yyy                 # 워크스페이스 B의 Integration Token

# ── Claude (Anthropic) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── 이메일 (Brevo SMTP API) ───────────────────────────────
BREVO_API_KEY=xkeysib-...
GMAIL_USER=your@email.com                    # Brevo 발신자 주소로 표시됨

# ── 수신자 (콤마 또는 줄바꿈으로 여러 명 지정 가능) ────────
RECIPIENT_EMAILS=someone@email.com, other@email.com

# ── 웹훅 보안 토큰 (노션 버튼 설정과 동일하게 맞춤) ────────
WEBHOOK_SECRET=your-strong-random-secret-here
