# ── Notion ────────────────────────────────────────────────
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxx

# ── Claude (Anthropic) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxx

# ── 이메일 (Brevo SMTP API) ───────────────────────────────
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxx
GMAIL_USER=your-sender@gmail.com        # Brevo 발신자 주소로 표시됨

# ── 수신자 (콤마 또는 줄바꿈으로 여러 명 지정 가능) ────────
RECIPIENT_EMAILS=user1@example.com,user2@example.com

# ── 웹훅 보안 토큰 (노션 버튼 설정과 동일하게 맞춤) ────────
WEBHOOK_SECRET=your-strong-random-secret-here
